    {
      "parameters": {
        "jsCode": "// ===============================\n// PROFESSIONAL FAQ MATCH ENGINE\n// ===============================\n\n// --- Text normalization ---\nfunction normalize(text) {\n  if (!text || typeof text !== \"string\") return \"\";\n  return text\n    .toLowerCase()\n    .replace(/[^a-z0-9\\s]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\n// --- Stopwords to ignore ---\nconst STOPWORDS = new Set([\n  \"how\",\"what\",\"when\",\"where\",\"why\",\"will\",\"can\",\"do\",\"does\",\"is\",\"are\",\n  \"i\",\"we\",\"you\",\"a\",\"an\",\"the\",\"to\",\"for\",\"of\",\"on\",\"in\",\"get\"\n]);\n\n// --- Get user message from CLEAN_INPUT ---\nconst userRaw = $node[\"CLEAN_INPUT\"].json.message_text || \"\";\nconst userText = normalize(userRaw);\n\nif (!userText) {\n  return {\n    matched: false,\n    score: 0,\n    faq: null,\n    reason: \"Empty user message\"\n  };\n}\n\n// --- Load FAQ rows ---\nconst faqs = items || [];\n\nlet bestMatch = null;\nlet bestScore = 0;\n\nfor (const item of faqs) {\n  if (!item.json || !item.json.Question) continue;\n\n  const faqText = normalize(item.json.Question);\n\n  // 1️⃣ EXACT / NEAR-EXACT MATCH\n  if (userText === faqText) {\n    return {\n      matched: true,\n      score: 100,\n      faq: item.json,\n      reason: \"Exact match\"\n    };\n  }\n\n  // 2️⃣ STRONG SUBSTRING MATCH (either direction)\n  if (userText.includes(faqText) || faqText.includes(userText)) {\n    return {\n      matched: true,\n      score: 90,\n      faq: item.json,\n      reason: \"Substring match\"\n    };\n  }\n\n  // 3️⃣ KEYWORD COVERAGE MATCH\n  const faqWords = faqText\n    .split(\" \")\n    .filter(w => w.length > 2 && !STOPWORDS.has(w));\n\n  if (faqWords.length === 0) continue;\n\n  let hits = 0;\n  for (const w of faqWords) {\n    if (userText.includes(w)) hits++;\n  }\n\n  const coverage = hits / faqWords.length;\n\n  if (coverage > bestScore) {\n    bestScore = coverage;\n    bestMatch = item.json;\n  }\n}\n\n// --- Final decision threshold ---\nif (bestScore >= 0.6) {\n  return {\n    matched: true,\n    score: Math.round(bestScore * 100),\n    faq: bestMatch,\n    reason: \"Keyword coverage\"\n  };\n}\n\n// --- No match ---\nreturn {\n  matched: false,\n  score: 0,\n  faq: null,\n  reason: \"No FAQ match\"\n};\n"
      },
