    {
      "parameters": {
        "jsCode": "const inputItems = $items(\"Check LEADS Sheet\");\n\nreturn inputItems.map(item => {\n  const email = item.json.Email;\n\n  const exists =\n    typeof email === \"string\" &&\n    email.includes(\"@\") &&\n    email.trim() !== \"\";\n\n  return {\n    json: {\n      ...item.json,   // ✅ KEEP original data (VERY IMPORTANT)\n      exists: exists\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -160,
        128
      ],
      "id": "4b369a3c-2eb1-4e8c-8194-f81b6e613ee5",
      "name": "LEAD_EXISTS_CHECK"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const fromRaw = item.json.From || \"\";\n\n  const emailMatch = fromRaw.match(/<(.+)>/);\n  const fromEmail = emailMatch\n    ? emailMatch[1].toLowerCase().trim()\n    : fromRaw.toLowerCase().trim();\n\n  let fromName = fromRaw.split(\"<\")[0].trim();\n  fromName = fromName.replace(/^\"|\\\"$/g, \"\");\n  if (!fromName) fromName = \"Unknown\";\n\n  let message = item.json.textPlain || item.json.snippet || \"\";\n  message = message.replace(/\\r?\\n|\\r/g, \" \").trim();\n\n  // 🚨 SMART BLOCK SYSTEM (THIS IS THE FIX)\n  const blockedPatterns = [\n    \"noreply\",\n    \"no-reply\",\n    \"do-not-reply\",\n    \"donotreply\",\n    \"notification\",\n    \"notifications\",\n    \"mailer-daemon\"\n  ];\n\n  const isBlocked = blockedPatterns.some(pattern =>\n    fromEmail.includes(pattern)\n  );\n\n  return {\n    json: {\n      clean_email: fromEmail,\n      clean_name: fromName,\n      message_text: message,\n      is_blocked: isBlocked   // 👈 IMPORTANT FLAG\n    }\n  };\n});"
      },
